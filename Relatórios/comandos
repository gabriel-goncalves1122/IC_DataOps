--- 1. GIT & PERMISSÕES (LINUX) ---
# Usar quando o Git der erro de "Permission denied" ou não conseguir trocar de branch
# (Isso acontece porque o Docker cria arquivos como root na pasta volumes)
sudo chown -R $USER:$USER .

--- 2. DOCKER COMPOSE (DIA A DIA) ---
# Subir todo o ambiente (Kafka, Druid, Superset) em segundo plano
docker compose up -d

# Subir forçando a reconstrução da imagem do Superset (após alterar Dockerfile)
docker compose up -d --build

# Parar e remover os containers (mas mantém os dados nos volumes)
docker compose down

# Ver se todos os containers estão "Up" (Rodando) ou "Exited" (Parados)
docker compose ps

--- 3. DOCKER (RESOLUÇÃO DE PROBLEMAS / LIMPEZA) ---
# Se der erro de "Name already in use" ou conflito de portas, rode esta sequência:

# 1. Derruba o compose oficial
docker compose down

# 2. Força a remoção de containers "fantasmas" ou travados
docker rm -f zookeeper zookeeper-kafka kafka postgres coordinator broker historical middlemanager router superset

# 3. Limpa redes órfãs
docker network prune -f

# 4. Sobe tudo limpo
docker compose up -d --build

--- 4. CONFIGURAÇÃO INICIAL DO SUPERSET (APENAS 1ª VEZ) ---
# Se você formatar o PC ou apagar os volumes, rode nesta ordem:

# A. Criar Usuário Admin
docker exec -it superset superset fab create-admin \
              --username admin \
