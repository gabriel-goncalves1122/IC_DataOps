--- 6. QUERIES SQL IMPORTANTES (DRUID CONSOLE) ---

-- A. Latência Média (O "Placar" Kafka vs NASA API)
SELECT 
  "metric_name",
  CAST(AVG("value") AS DECIMAL(10,2)) as tempo_medio_ms,
  CAST(MAX("value") AS DECIMAL(10,2)) as pior_caso_ms
FROM "system-metrics"
WHERE "unit" = 'ms'
GROUP BY 1
ORDER BY tempo_medio_ms DESC

-- B. Vazão (Mensagens por Minuto)
SELECT 
  TIME_FLOOR(__time, 'PT1M') as minuto,
  SUM("value") as total_registros
FROM "system-metrics"
WHERE "metric_name" = 'kafka_ingest_count'
GROUP BY 1
ORDER BY 1 DESC

