# --- OTIMIZAÇÃO DE MEMÓRIA (MODO ECONOMIA) ---

# Memória Heap Global (Reduzido de 1g/Auto para 512m)
DRUID_XMX=512m
DRUID_XMS=512m

# Tamanho de buffers e memória direta (Crucial para não estourar a RAM)
DRUID_MAXDIRECTMEMORYSIZE=1g
DRUID_SINGLE_NODE_CONF=micro-quickstart

# Configuração de Logs
druid_emitter_logging_logLevel=info

# Extensões (Mantenha apenas o necessário)
druid_extensions_loadList=["druid-histogram","druid-datasketches","druid-lookups-cached-global","postgresql-metadata-storage","druid-multi-stage-query","druid-kafka-indexing-service"]

# Conexão com Zookeeper e Postgres
druid_zk_service_host=zookeeper
druid_metadata_storage_host=
druid_metadata_storage_type=postgresql
druid_metadata_storage_connector_connectURI=jdbc:postgresql://postgres:5432/druid
druid_metadata_storage_connector_user=druid
druid_metadata_storage_connector_password=druid

# --- AJUSTES DO MIDDLEMANAGER (O MAIOR VILÃO DA RAM) ---

# Configuração das Tarefas (Peons):
# Antes estava 1GB Heap + 3GB Direct.
# AGORA: 256MB Heap + 512MB Direct.
druid_indexer_runner_javaOptsArray=["-server", "-Xmx256m", "-Xms256m", "-XX:MaxDirectMemorySize=512m", "-Duser.timezone=UTC", "-Dfile.encoding=UTF-8", "-Djava.util.logging.manager=org.apache.logging.log4j.jul.LogManager"]

# Limita o número de tarefas simultâneas (Para não abrir 10 processos Java)
druid_worker_capacity=2

# Reduz o buffer de ingestão (Antes 256MiB)
druid_indexer_fork_property_druid_processing_buffer_sizeBytes=64MiB

# --- ARMAZENAMENTO ---
druid_storage_type=local
druid_storage_storageDirectory=/opt/shared/segments
druid_indexer_logs_type=file
druid_indexer_logs_directory=/opt/shared/indexing-logs

# --- PROCESSAMENTO (CPU) ---
# Reduz threads para aliviar a CPU do notebook
druid_processing_numThreads=1
druid_processing_numMergeBuffers=1

# Log4j Config
DRUID_LOG4J=<?xml version="1.0" encoding="UTF-8" ?><Configuration status="WARN"><Appenders><Console name="Console" target="SYSTEM_OUT"><PatternLayout pattern="%d{ISO8601} %p [%t] %c - %m%n"/></Console></Appenders><Loggers><Root level="info"><AppenderRef ref="Console"/></Root><Logger name="org.apache.druid.jetty.RequestLog" additivity="false" level="WARN"><AppenderRef ref="Console"/></Logger></Loggers></Configuration>