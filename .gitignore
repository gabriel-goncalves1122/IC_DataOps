# ==========================================
# 1. AMBIENTES VIRTUAIS E CACHE PYTHON
# ==========================================
venv/
.venv/
env/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# ==========================================
# 2. DADOS MASSIVOS E GEOGRÁFICOS (CRÍTICO)
# ==========================================
# Ignora todo o conteúdo das subpastas de dados
data/geo/*
data/processed/*
data/raw/*
data/results/*

# Ignora extensões de arquivos de dados pesados em qualquer lugar
*.csv
*.xlsx
*.geojson
*.parquet
*.json.gz
*.shp
*.shx
*.dbf
*.prj

# Arquivo de controle de estado
checkpoint_ingestao.txt

# ==========================================
# 3. KAFKA E LOGS
# ==========================================
ApacheKafka/
logs/
*.log
*.out

# ==========================================
# 4. VOLUMES DOCKER (Caso mapeados localmente)
# ==========================================
metadata_data/
middle_var/
historical_var/
broker_var/
coordinator_var/
router_var/
druid_shared/

# ==========================================
# 5. IDEs E SISTEMA OPERACIONAL
# ==========================================
.vscode/
.idea/
.DS_Store
Thumbs.db
~$*

# ==========================================
# 6. EXCEÇÕES (O QUE DEVE SER VERSIONADO)
# ==========================================
# Mantém a estrutura de pastas de dados no Git (requer criar um arquivo .gitkeep vazio nelas)
!data/geo/.gitkeep
!data/processed/.gitkeep
!data/raw/.gitkeep
!data/results/.gitkeep

# Força o Git a aceitar os arquivos JSON do Druid e o ZIP do Superset na pasta infrastructure
!infrastructure/druid_specs/*.json
!infrastructure/superset/*.zip