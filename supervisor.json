{
  "type": "kafka",
  "spec": {
    "dataSchema": {
      "dataSource": "queimadas_focos_calor",
      "timestampSpec": {
        "column": "data_hora",
        "format": "auto"
      },
      "dimensionsSpec": {
        "dimensions": [
          { "name": "lat", "type": "double" },
          { "name": "lon", "type": "double" },
          "satelite",
          "estado",
          "bioma",
          "municipio",
          { "name": "em_terra_indigena", "type": "string" },
          "nome_ti",
          "linha_afetada",
          "voltagem_linha",
          "subestacao_afetada",
          "risco_eletrico"
        ]
      },
      "metricsSpec": [
        { "name": "total_focos", "type": "count" },
        { "name": "frp_maximo", "type": "doubleMax", "fieldName": "frp" },
        { "name": "dist_linha_minima_km", "type": "doubleMin", "fieldName": "dist_linha_km" },
        { "name": "dist_subestacao_minima_km", "type": "doubleMin", "fieldName": "dist_subestacao_km" }
      ],
      "granularitySpec": {
        "type": "uniform",
        "segmentGranularity": "HOUR",
        "queryGranularity": "NONE",
        "rollup": false
      }
    },
    "ioConfig": {
      "topic": "focos_calor",
      "inputFormat": {
        "type": "json"
      },
      "consumerProperties": {
        "bootstrap.servers": "kafka:9092"
      },
      "taskCount": 1,
      "replicas": 1,
      "taskDuration": "PT1H",
      "useEarliestOffset": true
    },
    "tuningConfig": {
      "type": "kafka",
      "maxRowsInMemory": 50000,
      "workerThreads": 1,
      "maxRowsPerSegment": 1000000,
      "resetOffsetAutomatically": true
    }
  }
}